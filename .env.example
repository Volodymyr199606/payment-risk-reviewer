# Copy to `.env.local` for local dev (never commit `.env.local`).
# On Vercel: Project → Settings → Environment Variables (Production + Preview).

# --- Optional: Groq (server-only) ---
GROQ_API_KEY=
# Set to "false" to force template-only analyst summary
ENABLE_GROQ_EXPLANATION=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Optional: Supabase persistence (server-only) ---
# Supabase Dashboard → Project Settings → API:
#   - Project URL     → SUPABASE_URL (e.g. https://xxxx.supabase.co)
#   - service_role    → SUPABASE_SERVICE_ROLE_KEY (secret; bypasses RLS for API routes)
# Do NOT use the anon/public key here — inserts require the service role (or RLS policies for anon).
# If either variable is missing, POST /api/review still returns 200; persistence is skipped.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
