# Copy to `.env.local` for local dev (never commit `.env.local`).
# On Vercel: Project → Settings → Environment Variables (Production + Preview).

# --- Reviewer Agent (Groq) — server-only; required for LLM analyst summary ---
# Create an API key at https://console.groq.com/keys — never expose to the browser.
# The agent orchestrates review; deterministic rules remain the decision backbone.
# Without GROQ_API_KEY, the API still returns 200 using template analystSummary.
GROQ_API_KEY=
# Set to "false" to force template-only summary (e.g. offline demo; Groq not called).
ENABLE_GROQ_EXPLANATION=
# Default in code: llama-3.3-70b-versatile — must be a model your key can access.
GROQ_MODEL=llama-3.3-70b-versatile

# --- Optional: Supabase persistence (server-only) ---
# Supabase Dashboard → Project Settings → API:
#   - Project URL     → SUPABASE_URL (e.g. https://xxxx.supabase.co)
#   - service_role    → SUPABASE_SERVICE_ROLE_KEY (secret; bypasses RLS for API routes)
# Do NOT use the anon/public key here — inserts require the service role (or RLS policies for anon).
# If either variable is missing, POST /api/review still returns 200; persistence is skipped.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
